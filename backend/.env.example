NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://cmms:cmms@localhost:5432/cmms

# Google Cloud OAuth 2.0 Web client (see README for setup).
# Placeholders keep the server bootable; real Drive/Docs calls need real values.
GOOGLE_CLIENT_ID=placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=placeholder-secret
# MUST byte-match the Authorized redirect URI in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# Any random string of 32+ chars (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars
JWT_EXPIRES_IN=7d

# Where the SPA runs; OAuth callback redirects back here.
FRONTEND_URL=http://localhost:5173

# Dev-only: enables POST /api/v1/auth/dev-login (ignored when NODE_ENV=production)
ALLOW_DEV_LOGIN=true
